<?xml version="1.0"?>
<rdf:RDF xmlns="https://github.com/bakariwie/scon-ontology#"
     xml:base="https://github.com/bakariwie/scon-ontology"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:scon="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:scon-ontology="https://github.com/bakariwie/scon-ontology#">
    <owl:Ontology rdf:about="https://github.com/bakariwie/scon-ontology">
        <owl:versionIRI rdf:resource="https://github.com/bakariwie/scon-ontology-1/1.0.0"/>
        <dcterms:bibliographicCitation xml:lang="en">Bakariwie, A., Weyori, B. A., and Afriyie, Y. (in press). Ontology-based knowledge representation for school counselling: A systematic literature review of ontology artefacts and semantic web technologies. Discover Artificial Intelligence. Advance online publication.</dcterms:bibliographicCitation>
        <dcterms:contributor>Benjamin A. Weyori</dcterms:contributor>
        <dcterms:contributor>Yaw Afriyie</dcterms:contributor>
        <dcterms:created>2026-06</dcterms:created>
        <dcterms:creator>Amiru Bakariwie</dcterms:creator>
        <dcterms:description xml:lang="en">SCON is a modular, reasoning-enabled domain ontology for comprehensive counselling in school and higher-education institutional environments, engineered to support the construction of intelligent counselling systems (chatbots, socially assistive robots, recommender and early-warning systems). It is grounded in the ASCA National Model and the ASCA Student Standards (Mindsets and Behaviors), aligned to Basic Formal Ontology (BFO) as top-level ontology, and reuses OBO Foundry ontologies (IAO, RO, OBI, MFOEM) and the W3C Time Ontology, with vocabulary informed by CASEL, DOMASEC, the Big Five taxonomy, the ERIC Thesaurus, UNESCO ISCED, IEEE LOM, O*NET, ESCO, OccO, and EduCOR. Engineered following the NeOn methodology (Scenario 4: ontology networks) and the Linked Open Terms workflow; populated with assistance from the large language model Claude (Anthropic) under human expert adjudication and a HermiT consistency gate.</dcterms:description>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dcterms:title xml:lang="en">SCON: School Counselling Ontology Network</dcterms:title>
        <scon:competencyQuestion xml:lang="en">A-CQ1 [academic]: Which ASCA Mindsets and Behaviors standards in the academic domain are prioritised by the programme&apos;s annual student outcome goals for a given grade level?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ10 [academic]: Which self-management skills (B-SMS), such as perseverance and delayed gratification, are associated with a student&apos;s academic engagement?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ11 [academic]: Which referrals to academic support services, such as tutoring or special-education evaluation, follow from an identified academic concern, and what is the escalation pathway?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ12 [academic]: Which academic interventions are contra-indicated or duplicated within a student&apos;s current support plan, and how is this detected by the reasoner?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ2 [academic]: Which academic indicators - course grades, credit accrual, assessment results, and attendance - flag a student for Tier 2 targeted support, and from which data sources is each derived?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ3 [academic]: Which closing-the-gap action plan addresses an identified academic equity gap, and which students constitute its target group according to disaggregated achievement data?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ4 [academic]: Which classroom lessons (Tier 1 instruction) address a given academic Mindsets and Behaviors standard, and in which grade levels are they delivered?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ5 [academic]: Which learning-strategies behaviours (B-LS), such as time management, study skills, and critical thinking, has a student demonstrated or not yet demonstrated?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ6 [academic]: Which small-group interventions target low academic achievement, and what participation, Mindsets and Behaviors, and outcome data are recorded in their results reports?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ7 [academic]: How does a student&apos;s academic record map to graduation requirements, promotion criteria, and course prerequisites?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ8 [academic]: Which appraisal and advisement activities support a student&apos;s course selection and academic goal setting within individual student planning?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">A-CQ9 [academic]: How is progress towards an annual student outcome goal in the academic domain measured across the sequence of lessons, groups, and interventions delivered?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ1 [career]: Which career-development Mindsets and Behaviors standards are addressed by the programme&apos;s Tier 1 career lessons at each grade level?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ10 [career]: Which college- and career-application milestones, including applications, financial-aid submissions, and scholarship deadlines, has a student completed or missed?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ11 [career]: Which career interventions demonstrate effectiveness through the participation, Mindsets and Behaviors, and outcome data of their results reports?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ12 [career]: Which employability behaviours, transferable across the Mindsets and Behaviors categories, evidence a student&apos;s career readiness?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ2 [career]: Which career assessments, including interest inventories and aptitude and values assessments, inform a student&apos;s postsecondary and career plan?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ3 [career]: Which career clusters and occupations align with a student&apos;s assessed interests, aptitudes, and constraints?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ4 [career]: Which postsecondary plan exists for a student, and which appraisal and advisement sessions produced or revised it?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ5 [career]: Which work-based learning experiences, such as job shadowing, internships, and service learning, has a student completed, and which standards do they evidence?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ6 [career]: How do a student&apos;s course selections map to a chosen career pathway and to its postsecondary entry requirements?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ7 [career]: Which students lack a documented postsecondary plan by a milestone grade, as targeted by a closing-the-gap action plan?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ8 [career]: Which career-planning resources and tools are recommended for a student&apos;s developmental stage and identified needs?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">C-CQ9 [career]: How is a student&apos;s progression along a career-guidance pathway monitored across grade-level transitions?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ1 [social-emotional]: Which social/emotional Mindsets and Behaviors standards are prioritised by the annual student outcome goals, and for which student populations?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ10 [social-emotional]: Which referrals to community mental-health providers extend support beyond the short-term counselling remit of the school counsellor?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ11 [social-emotional]: How is the effectiveness of social/emotional interventions evidenced through participation, Mindsets and Behaviors, and outcome data?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ12 [social-emotional]: Which self-management interventions reduce discipline incidents for the target group of a closing-the-gap action plan?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ2 [social-emotional]: Which behavioural and socio-emotional indicators - discipline referrals, screening results, self-report, and teacher report - flag a student for Tier 2 or Tier 3 support?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ3 [social-emotional]: How is the severity or urgency of a socio-emotional risk classified to prioritise response, including activation of suicide-risk assessment protocols?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ4 [social-emotional]: Which short-term, small-group counselling interventions address an identified social/emotional concern, and what is their evidence base?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ5 [social-emotional]: Which safeguarding concerns trigger mandated reporting, and to which internal role or external agency is each referred?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ6 [social-emotional]: Which social-skills behaviours (B-SS), such as empathy, positive relationships, and responsible decision making, has a student demonstrated across settings?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ7 [social-emotional]: Which consent conditions and confidentiality constraints govern access to, and disclosure of, a student&apos;s counselling record?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ8 [social-emotional]: Which crisis-response procedures apply to a given crisis type, and which institutional roles participate in the response?</scon:competencyQuestion>
        <scon:competencyQuestion xml:lang="en">S-CQ9 [social-emotional]: How are a student&apos;s emotion processes and behavioural observations documented across successive sessions as a developmental trajectory?</scon:competencyQuestion>
        <rdfs:seeAlso rdf:resource="https://github.com/bakariwie/scon-ontology"/>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


