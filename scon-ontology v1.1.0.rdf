        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#IntelligentCounsellingSystem"/>
        <obo:IAO_0000115 xml:lang="en">An intelligent counselling system whose outputs are grounded in a counselling knowledge base.</obo:IAO_0000115>
        <module>intelligent-systems</module>
        <populationProvenance>author-vocabulary (defined class, v1.1.0)</populationProvenance>
        <rdfs:label xml:lang="en">knowledge-grounded counselling system</rdfs:label>
    </owl:Class>
    


