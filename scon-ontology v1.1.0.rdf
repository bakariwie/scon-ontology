    <!-- http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#HighRiskStudent -->

    <owl:Class rdf:about="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#HighRiskStudent">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#Student"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#hasRiskIndicator"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#hasRiskLevel"/>
                                <owl:hasValue rdf:resource="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#riskLevel_high"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#Student"/>
        <obo:IAO_0000115 xml:lang="en">A student who bears a risk indicator whose assigned risk level is high.</obo:IAO_0000115>
        <module>risk-safeguarding</module>
        <populationProvenance>author-vocabulary (defined class, v1.1.0)</populationProvenance>
        <rdfs:label xml:lang="en">high-risk student</rdfs:label>
    </owl:Class>
    


