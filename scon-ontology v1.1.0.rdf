    <!-- http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#KnowledgeGroundedCounsellingSystem -->

    <owl:Class rdf:about="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#KnowledgeGroundedCounsellingSystem">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#IntelligentCounsellingSystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#groundedInKB"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/bakariwie/ontologies/2026/6/scon-ontology-1#CounsellingKnowledgeBase"/>
                    </owl:Restriction>
                </owl:intersectionOf>
